@page "/users"
@using CleanArchitecture.WebUI.Services
@using CleanArchitecture.WebUI.Services.Models
@inject AuthClient Client
@inject ISnackbar Snackbar
@attribute [Authorize(Roles = "Admin")]

<div class="d-flex align-center justify-space-between mb-6">
    <div>
        <MudText Typo="Typo.h3" Class="font-weight-bold" Color="Color.Primary">User Management</MudText>
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mt-1">Manage application users, assign roles, and control access.</MudText>
    </div>
</div>

@if (_isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudDataGrid T="UserDto" Items="@_users" MultiSelection="true" Elevation="4" Dense="false" Hover="true" Striped="false"
                 Class="rounded-xl border-solid border-2 mud-border-lines-default" 
                 Style="background: var(--mud-palette-surface);" QuickFilter="@_quickFilter">
        <ToolBarContent>
            <MudIcon Icon="@Icons.Material.Rounded.PeopleAlt" Color="Color.Primary" Class="mr-3" />
            <MudText Typo="Typo.h6" Class="font-weight-bold">Registered Users</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" Placeholder="Search by Name or Email" Adornment="Adornment.Start" Immediate="true"
                          AdornmentIcon="@Icons.Material.Rounded.Search" IconSize="Size.Medium" Class="mt-0" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
        </ToolBarContent>
        <Columns>
            <SelectColumn T="UserDto" />
            <PropertyColumn Property="x => x.FullName" Title="Full Name" />
            <PropertyColumn Property="x => x.Email" Title="Email" />
            <TemplateColumn Title="Current Role" Sortable="false">
                <CellTemplate>
                    @{
                        var role = context.Item.Roles.FirstOrDefault() ?? "None";
                        var badgeColor = role == "Admin" ? "var(--mud-palette-error)" : "var(--mud-palette-info)";
                        var badgeBg = role == "Admin" ? "rgba(var(--mud-palette-error-rgb), 0.1)" : "rgba(var(--mud-palette-info-rgb), 0.1)";
                    }
                    <div style="background-color: @badgeBg; border-radius: 8px; padding: 4px 12px; display: inline-flex; align-items: center; border: 1px solid rgba(var(--mud-palette-lines-default-rgb), 0.3);">
                        <div style="width: 8px; height: 8px; border-radius: 50%; background-color: @badgeColor; margin-right: 8px;"></div>
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold" Style="@($"color: {badgeColor}; text-transform: uppercase; font-size: 0.75rem;")">@role</MudText>
                    </div>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudMenu Icon="@Icons.Material.Rounded.MoreVert" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <MudMenuItem Icon="@Icons.Material.Rounded.Security" IconColor="Color.Error" OnClick="@(() => UpdateRole(context.Item, "Admin"))">Make Admin</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Rounded.Person" IconColor="Color.Info" OnClick="@(() => UpdateRole(context.Item, "Member"))">Make Member</MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Rounded.DeleteOutline" IconColor="Color.Default">Remove User</MudMenuItem>
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="UserDto" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    private List<UserDto> _users = new();
    private bool _isLoading = true;
    private string _searchString = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadUsers();
        }
    }

    private async Task LoadUsers()
    {
        _isLoading = true;
        StateHasChanged(); // Trigger render to show the loading indicator

        var result = await Client.GetUsersAsync();
        
        if (result.IsSuccess && result.Data != null)
        {
            _users = result.Data;
        }
        else
        {
            Snackbar.Add($"Failed to load users: {result.Error}", Severity.Error);
        }
        
        _isLoading = false;
        StateHasChanged(); // Trigger render to display the loaded data
    }

    private async Task UpdateRole(UserDto user, string newRole)
    {
        var currentRole = user.Roles.FirstOrDefault();
        if (currentRole == newRole) return;

        var result = await Client.UpdateUserRoleAsync(user.Email, newRole);

        if (result.IsSuccess)
        {
            Snackbar.Add($"Role for {user.Email} successfully updated to {newRole}", Severity.Success);
            
            // Update the local model so the UI reflects the change without a full reload
            user.Roles.Clear();
            user.Roles.Add(newRole);
        }
        else
        {
            Snackbar.Add($"Failed to update role: {result.Error}", Severity.Error);
            
            // Reload user list to restore original state if failed
            await LoadUsers();
        }
    }

    private Func<UserDto, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (x.FullName.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.Email.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    };
}
