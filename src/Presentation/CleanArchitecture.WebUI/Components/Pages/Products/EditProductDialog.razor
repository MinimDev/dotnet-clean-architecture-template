@using CleanArchitecture.WebUI.Services.Models
@using CleanArchitecture.WebUI.Services
@inject ProductsClient Client
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" IsValid="@_isValid">
            <MudTextField @bind-Value="Command.Name" Label="Product Name" Variant="Variant.Outlined" Required="true" RequiredError="Name is required!" Class="mb-4" />
            <MudTextField @bind-Value="Command.Description" Label="Description" Variant="Variant.Outlined" Lines="3" Class="mb-4" />
            <MudGrid>
                <MudItem xs="6">
                    <MudNumericField @bind-Value="Command.Price" Label="Price" Variant="Variant.Outlined" Required="true" Min="0" RequiredError="Price must be valid." />
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField @bind-Value="Command.Stock" Label="Stock Quantity" Variant="Variant.Outlined" Required="true" Min="0" RequiredError="Stock must be valid." />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Class="rounded-lg mr-2 text-transform-none font-weight-bold">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(_isSaving)" Class="rounded-lg px-6 text-transform-none font-weight-bold shadow-sm">
            @if (_isSaving)
            {
                <MudProgressCircular Class="ms-n1 mr-2" Size="Size.Small" Indeterminate="true" />
                <span>Saving...</span>
            }
            else
            {
                <span>Save Changes</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    
    [Parameter]
    public ProductDto Product { get; set; } = new();

    private UpdateProductDto Command { get; set; } = new();
    private MudForm _form = default!;
    private bool _isValid;
    private bool _isSaving;

    protected override void OnInitialized()
    {
        Command = new UpdateProductDto
        {
            Name = Product.Name,
            Description = Product.Description,
            Price = Product.Price,
            Stock = Product.Stock
        };
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            _isSaving = true;
            var result = await Client.UpdateProductAsync(Product.Id, Command);
            _isSaving = false;

            if (result.IsSuccess)
            {
                Snackbar.Add("Product updated successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add($"Failed to update product: {result.Error}", Severity.Error);
            }
        }
    }
}
