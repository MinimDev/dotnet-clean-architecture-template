@page "/products"
@using CleanArchitecture.WebUI.Services
@using CleanArchitecture.WebUI.Services.Models
@inject ProductsClient Client
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">
    <!-- Header Section -->
    <MudPaper Elevation="0" Class="pa-4 mb-6" Style="background-color: transparent;">
        <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="6" md="4">
                <MudText Typo="Typo.h3" Color="Color.Primary" Class="font-weight-bold">Products</MudText>
                <MudText Typo="Typo.subtitle1" Color="Color.Default">Browse our latest collections</MudText>
            </MudItem>
            
            <MudItem xs="12" sm="6" md="8">
                <MudGrid Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Spacing="2">
                    <MudItem xs="12" sm="8" md="6">
                        <MudTextField T="string" Value="@_searchString" ValueChanged="@OnSearchChanged" 
                                      Placeholder="Search products..." Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" 
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                      Class="rounded-lg bg-surface"></MudTextField>
                    </MudItem>
                    <AuthorizeView Roles="Admin">
                        <Authorized>
                            <MudItem xs="12" sm="4" md="4">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" 
                                           OnClick="CreateProduct" Size="Size.Large" Class="rounded-lg full-width">
                                    New Product
                                </MudButton>
                            </MudItem>
                        </Authorized>
                    </AuthorizeView>
                </MudGrid>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- Product Grid Section -->
    @if (_isLoading)
    {
        <MudGrid>
            @for (int i = 0; i < 8; i++)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Elevation="3" Class="rounded-xl overflow-hidden">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" />
                        <MudCardContent>
                            <MudSkeleton Width="70%" Height="32px;" Class="mb-4" />
                            <MudSkeleton Width="40%" />
                            <MudSkeleton Width="100%" />
                        </MudCardContent>
                        <MudCardActions>
                            <MudSkeleton Width="64px" Height="40px" Class="ml-2" />
                            <MudSkeleton Width="64px" Height="40px" Class="ml-2" />
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else if (_products == null || !_products.Any())
    {
        <MudPaper Elevation="0" Class="pa-12 text-center d-flex flex-column align-center justify-center rounded-xl mud-width-full" Style="min-height: 500px; background-color: transparent; border: 1px dashed var(--mud-palette-lines-default);">
            <svg width="200" height="200" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="mb-6 opacity-80">
                <path d="M21 7V17C21 20 19.5 22 16 22H8C4.5 22 3 20 3 17V7C3 4 4.5 2 8 2H16C19.5 2 21 4 21 7Z" stroke="var(--mud-palette-primary-lighten)" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14.5 4.5V6.5C14.5 7.6 15.4 8.5 16.5 8.5H18.5" stroke="var(--mud-palette-primary-lighten)" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8 13H12" stroke="var(--mud-palette-primary)" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8 17H16" stroke="var(--mud-palette-primary)" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <MudText Typo="Typo.h5" Color="Color.Default" Class="font-weight-bold mb-3" Style="letter-spacing: -0.02em;">No Products Found</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-8 max-w-sm">You haven't added any products to your inventory yet. Let's create your first product to get started!</MudText>
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="px-8 py-3 rounded-lg font-weight-bold shadow-sm" StartIcon="@Icons.Material.Rounded.Add" OnClick="CreateProduct">
                        Create Your First Product
                    </MudButton>
                </Authorized>
            </AuthorizeView>
        </MudPaper>
    }
    else
    {
        <MudGrid Spacing="4">
            @foreach (var product in _products)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Elevation="4" Class="rounded-xl overflow-hidden hover-elevation flex-column d-flex h-100 transition-all border-solid border-2 mud-border-lines-default" Style="transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1);">
                        <!-- Dynamic Gradient Image Area -->
                        <div class="d-flex align-center justify-center" style="@($"height: 180px; {GetGradient(product.Id.ToString())} position: relative;")">
                            <MudIcon Icon="@Icons.Material.Rounded.Inventory2" Style="font-size: 5rem; color: rgba(255,255,255,0.9); filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));" />
                            <div style="position: absolute; top: 12px; right: 12px; background: rgba(255,255,255,0.2); backdrop-filter: blur(8px); border-radius: 12px; padding: 2px;">
                                @if (product.Status == "Active")
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled" Class="font-weight-bold ma-0" Style="box-shadow: 0 2px 4px rgba(16,185,129,0.3);">ACTIVE</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled" Class="font-weight-bold ma-0">@product.Status.ToUpper()</MudChip>
                                }
                            </div>
                        </div>

                        <MudCardContent Class="flex-grow-1 pb-2 pt-5">
                            <div class="d-flex justify-space-between align-start mb-2">
                                <MudText Typo="Typo.h5" Class="font-weight-bold line-clamp-2" Style="line-height: 1.25; letter-spacing: -0.02em;">
                                    @product.Name
                                </MudText>
                            </div>
                            
                            <MudText Typo="Typo.h4" Color="Color.Primary" Class="font-weight-bold mb-4" Style="letter-spacing: -0.03em;">
                                @(product.Price > 0 ? product.PriceDisplay : "Free")
                            </MudText>

                            <MudDivider Class="mb-3" />

                            <div class="d-flex align-center gap-2 mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Stock: <b>@product.Stock units</b>
                                </MudText>
                            </div>

                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Event" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Added: @product.CreatedAt.ToString("MMM dd, yyyy")
                                </MudText>
                            </div>
                        </MudCardContent>

                        <MudCardActions Class="pa-4 pt-0 d-flex justify-end gap-2">
                            <AuthorizeView Roles="Admin">
                                <Authorized>
                                    <MudTooltip Text="Edit Product">
                                        <MudIconButton Icon="@Icons.Material.Outlined.Edit" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small" Class="rounded-lg hover-bg-primary" OnClick="@(() => EditProduct(product))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete Product">
                                        <MudIconButton Icon="@Icons.Material.Outlined.Delete" Color="Color.Error" Variant="Variant.Outlined" Size="Size.Small" Class="rounded-lg hover-bg-error" OnClick="@(() => DeleteProduct(product))" />
                                    </MudTooltip>
                                </Authorized>
                            </AuthorizeView>
                            <MudTooltip Text="View Details">
                                <MudIconButton Icon="@Icons.Material.Rounded.ArrowForward" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="rounded-lg ml-auto" OnClick="@(() => ViewProductDetail(product))" />
                            </MudTooltip>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>

        <!-- Pagination -->
        <div class="d-flex justify-center mt-8 mb-4">
            <MudPagination Color="Color.Primary" Count="@_totalPages" Selected="@_currentPage" SelectedChanged="OnPageChanged" 
                           ShowFirstButton="true" ShowLastButton="true" Variant="Variant.Filled" Class="rounded-xl shadow-sm"/>
        </div>
    }
</MudContainer>

<style>
    .hover-elevation:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
        border-color: var(--mud-palette-primary) !important;
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
    .hover-bg-primary:hover {
        background-color: var(--mud-palette-primary-hover);
        color: var(--mud-palette-primary) !important;
        border-color: var(--mud-palette-primary);
    }
    .hover-bg-error:hover {
        background-color: var(--mud-palette-error-hover);
        color: var(--mud-palette-error) !important;
        border-color: var(--mud-palette-error);
    }
</style>

@code {
    private List<ProductDto> _products = new();
    private bool _isLoading = true;
    private string _searchString = "";
    
    // Pagination state
    private int _currentPage = 1;
    private int _pageSize = 8;
    private int _totalPages = 1;
    private int _totalItems = 0;

    private string GetGradient(string id)
    {
        // Generate a pseudo-random cool gradient based on the item's Guid
        var hash = id.GetHashCode();
        var hue1 = Math.Abs(hash % 360);
        var hue2 = (hue1 + 40) % 360;
        return $"background: linear-gradient(135deg, hsl({hue1}, 80%, 65%) 0%, hsl({hue2}, 70%, 50%) 100%);";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadProducts();
        }
    }

    private async Task OnSearchChanged(string text)
    {
        _searchString = text;
        _currentPage = 1; // Reset to first page on new search
        await LoadProducts();
    }

    private async Task OnPageChanged(int i)
    {
        _currentPage = i;
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        _isLoading = true;
        StateHasChanged();

        var result = await Client.GetProductsAsync(_currentPage, _pageSize, _searchString);

        if (result.IsSuccess && result.Data != null)
        {
            _products = result.Data.Items.ToList();
            _totalItems = result.Data.TotalCount;
            _totalPages = (int)Math.Ceiling((double)_totalItems / _pageSize);
            if (_totalPages == 0) _totalPages = 1;
        }
        else
        {
            _products = new List<ProductDto>();
            _totalPages = 1;
            // Show diagnostic error in Snackbar so the failure reason is visible in the UI
            Snackbar.Add($"Load failed: {result.Error}", Severity.Error);
        }

        _isLoading = false;
        StateHasChanged();
    }

    private async Task CreateProduct()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateProductDialog>("New Product", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            _currentPage = 1; // Return to first page to see the new product
            await LoadProducts();
        }
    }

    private async Task EditProduct(ProductDto product)
    {
        var parameters = new DialogParameters { ["Product"] = product };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EditProductDialog>("Edit Product", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadProducts();
        }
    }

    private async Task DeleteProduct(ProductDto product)
    {
        bool? dialogResult = await DialogService.ShowMessageBox(
            "Delete Product",
            $"Are you sure you want to delete {product.Name}?",
            yesText: "Delete", cancelText: "Cancel");

        if (dialogResult == true)
        {
            var result = await Client.DeleteProductAsync(product.Id);
            if (result.IsSuccess)
            {
                Snackbar.Add("Product deleted successfully", Severity.Success);
                // Check if page became empty
                if (_products.Count == 1 && _currentPage > 1) 
                    _currentPage--;
                await LoadProducts();
            }
            else
            {
                Snackbar.Add($"Failed to delete product: {result.Error}", Severity.Error);
            }
        }
    }

    private async Task ViewProductDetail(ProductDto product)
    {
        var parameters = new DialogParameters { ["Product"] = product };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<ProductDetailDialog>($"Product Details - {product.Name}", parameters, options);
    }
}
