<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageType>Template</PackageType>
    <PackageId>Minimdev.CleanArchitecture.Template</PackageId>
    <Title>Clean Architecture Solution Template</Title>
    <Authors>Minimdev</Authors>
    <Description>Clean Architecture Solution Template by Minimdev. Features layered architecture (Core, Infrastructure, Presentation), .NET 10 support, Refresh Token system, Integration Tests, and full Visual Studio 2022 &amp; 2026 compatibility via 'dotnet new' or New Project dialog.</Description>
    <PackageTags>clean-architecture;csharp;dotnet-new;template;solution</PackageTags>
    <TargetFramework>net10.0</TargetFramework>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <ContentTargetFolders>content</ContentTargetFolders>
    <NoDefaultExcludes>true</NoDefaultExcludes>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/Minimdev/CleanArchitecture</PackageProjectUrl>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Version>1.5.1</Version>
    <PackageReleaseNotes>v1.5.1: Build compatibility fixes — MudBlazor v9 Typography FontWeight type (int→string), Swashbuckle.AspNetCore downgraded from v10 to v9 (OpenAPI v3 namespace breaking change), and Scalar API Reference UI replaced with CDN-based approach (Scalar.AspNetCore v2.14 bundle conflict).</PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="**\*" Exclude="**\bin\**;**\obj\**;**\.git\**;**\.github\**;**\.vs\**;*.nupkg;Minimdev.CleanArchitecture.Template.csproj;publish.ps1;verify_pack.ps1;**\*.log;**\*.user" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
